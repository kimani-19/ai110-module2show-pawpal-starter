classDiagram
    class Owner {
        +int owner_id
        +str name
        +str email
        +str phone
        +str address
        +list~Pet~ pets
        +add_pet(pet Pet) None
        +remove_pet(pet_id int) None
        +get_all_tasks() list~Task~
        +get_all_appointments() list~Appointment~
    }

    class Pet {
        +int pet_id
        +str name
        +str species
        +str breed
        +int age
        +float weight
        +str health_notes
        +Owner owner
        -list~Task~ _tasks
        -list~Appointment~ _appointments
        +add_task(task Task) None
        +mark_task_complete(task_id int) Task | None
        +get_upcoming_tasks() list~Task~
        +get_care_history() list~Task~
        +add_appointment(appt Appointment) None
        +get_upcoming_appointments() list~Appointment~
    }

    class Task {
        +int task_id
        +str title
        +str description
        +datetime due_date
        +bool is_complete
        +str priority
        +int duration_minutes
        +str category
        +str recurrence
        +Pet pet
        +datetime completed_at
        +mark_complete() None
        +reschedule(new_date datetime) None
        +is_overdue() bool
        +get_priority_score() int
        +get_next_due_date() datetime | None
    }

    class Appointment {
        +int appointment_id
        +str title
        +datetime date_time
        +str location
        +str vet_name
        +str appointment_type
        +str status
        +int duration_minutes
        +str notes
        +Pet pet
        +reschedule(new_datetime datetime) None
        +cancel() None
        +get_reminder() str
        +is_upcoming() bool
    }

    class Scheduler {
        +Owner owner
        +build_daily_plan(date datetime) list~Task~
        +get_overdue_tasks() list~Task~
        +suggest_next_task() Task | None
        +sort_by_time(tasks list~Task~) list~Task~
        +filter_tasks(pet_name str, is_complete bool) list~Task~
        +detect_conflicts(tasks list~Task~) list~str~
    }

    Owner "1" --> "0..*" Pet : owns
    Pet "1" --> "0..*" Task : has
    Pet "1" --> "0..*" Appointment : schedules
    Scheduler "1" --> "1" Owner : reads tasks/appointments from
